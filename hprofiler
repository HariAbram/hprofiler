#!/usr/bin/env python3
"""
hprofiler — multi-backend CPU/GPU profiler CLI

Usage examples:
  hprofiler run -- ./my_omp_program
  hprofiler run --backend omp -- ./my_omp_program        # alias for openmp
  hprofiler run --backend cuda,cpu -- ./my_cuda_app arg1 arg2
  hprofiler run --backend opencl,cpu --output trace.json -- ./acpp_program
  hprofiler run --backend rocm -- ./hip_program          # or: --backend hip
  hprofiler view trace.json
  hprofiler summary trace.json
  hprofiler backends          # list available backends on this system
"""

import sys
import os

# Add src to path so we can import without installing
sys.path.insert(0, os.path.join(os.path.dirname(__file__), "."))

import click
from pathlib import Path


# ── Helpers ──────────────────────────────────────────────────────────────────

def _available_backends() -> dict[str, bool]:
    from src.backends import ALL_BACKENDS
    return {name: cls().is_available() for name, cls in ALL_BACKENDS.items()}


_ALIASES: dict[str, str] = {
    "omp":    "openmp",
    "cl":     "opencl",
    "hip":    "rocm",
    "perf":   "cpu",
    "hwc":    "likwid",
}


def _resolve_backends(backend_str: str | None) -> list[str]:
    """Resolve comma-separated backend list (with aliases), defaulting to all available."""
    avail = _available_backends()
    if not backend_str or backend_str == "auto":
        chosen = [name for name, ok in avail.items() if ok]
        if not chosen:
            chosen = ["cpu"]
        return chosen
    requested = [_ALIASES.get(b.strip(), b.strip()) for b in backend_str.split(",")]
    unknown = [b for b in requested if b not in avail]
    if unknown:
        valid = list(avail.keys()) + list(_ALIASES.keys())
        click.echo(f"[warn] Unknown backends: {', '.join(unknown)} "
                   f"(valid: {', '.join(sorted(valid))})", err=True)
    return [b for b in requested if b in avail]


# ── CLI ───────────────────────────────────────────────────────────────────────

@click.group()
@click.version_option("0.1.0", prog_name="hprofiler")
def cli():
    """Multi-backend CPU/GPU profiler for Linux.

    Traces programs across CUDA, ROCm, OpenCL, OpenMP, NCCL, and MPI via
    LD_PRELOAD hooks and OMPT callbacks. CPU sampling is provided via Linux
    perf. All backends can run simultaneously.

    \b
    Backends:
      cpu      Linux perf — CPU samples and call-graph stacks
      cuda     CUDA Runtime + Driver API + NVTX — kernels, memcpy, sync
      opencl   OpenCL — kernel enqueues, buffer transfers, JIT compile time
      openmp   OpenMP OMPT — parallel regions, tasks, barriers, target offload
      rocm     ROCm/HIP — kernel launches, memcpy, device memory
      nccl     NCCL — AllReduce, Broadcast, Send/Recv (GPU-accurate timing)
      mpi      MPI — point-to-point, collectives, one-sided ops (PMPI)
      likwid   Hardware PMU counters via likwid-perfctr (FLOPS, bandwidth)

    \b
    Aliases:  omp=openmp  hip=rocm  cl=opencl  perf=cpu  hwc=likwid

    \b
    Quick start:
      hprofiler build                                  # compile hook libraries
      hprofiler backends                               # check what is available
      hprofiler run --backend cuda -- ./app            # profile a CUDA program
      hprofiler run -- ./app                           # auto-detect all backends
      hprofiler run --backend cuda,nccl -- ./app       # multiple backends
      hprofiler run --call-tree --backend cuda -- ./app  # + call tree from main
      hprofiler roofline --backend cuda -- ./app       # hardware roofline chart
      hprofiler flamegraph -- ./app                    # CPU flame graph SVG
      hprofiler view app.hprofiler.json                # reopen a saved trace

    \b
    Output written after every run:
      <prog>.hprofiler.json — Chrome Trace (open in ui.perfetto.dev)
      TUI viewer            — opens automatically (tabs: Overview, Timeline,
                              Hotspots, [Flame], [Call Tree], [Disasm])

    Always separate hprofiler options from the target program with --:

    \b
      hprofiler run --backend cuda -- ./app --flag   (correct)
      hprofiler run --backend cuda ./app --flag      (--flag parsed as profiler option)
    """


@cli.command(context_settings={"ignore_unknown_options": True, "allow_extra_args": True})
@click.option("--backend", "-b", default="auto",
              help="Comma-separated backends: cpu,cuda,opencl,rocm,openmp  [default: auto]")
@click.option("--output", "-o", default=None,
              help="Output trace file (JSON).  Default: <program>.hprofiler.json")
@click.option("--ui/--no-ui", default=True,
              help="Open the TUI viewer after profiling  [default: yes]")
@click.option("--summary/--no-summary", default=True,
              help="Print text summary after profiling  [default: yes]")
@click.option("--perf-freq", default=9999, show_default=True,
              help="perf sampling frequency (Hz)")
@click.option("--perf-callgraph", default=None,
              type=click.Choice(["fp", "dwarf", "lbr"]),
              help="perf call-graph method (disabled by default — use fp/dwarf/lbr for stacks)")
@click.option("--disasm/--no-disasm", default=False,
              help="Collect per-kernel disassembly after profiling  [default: no]")
@click.option("--call-tree/--no-call-tree", default=False,
              help="Capture CPU call stacks to build a from-main call tree  [default: no]")
@click.argument("command", nargs=-1, required=True, type=click.UNPROCESSED)
def run(backend, output, ui, summary, perf_freq, perf_callgraph, disasm, call_tree, command):
    """Profile COMMAND with the selected backends.

    Backends are injected via LD_PRELOAD (CUDA, OpenCL, ROCm, NCCL, MPI) or
    OMP_TOOL_LIBRARIES (OpenMP OMPT). The CPU backend runs perf record in
    parallel with the target process. All backends can be combined freely.

    \b
    Every run produces:
      <prog>.hprofiler.json  — Chrome Trace JSON (Perfetto / chrome://tracing)
      TUI viewer             — opened automatically unless --no-ui

    \b
    Examples:
      hprofiler run --backend cuda -- ./cuda_app
      hprofiler run --backend cuda,nccl -- ./multi_gpu_app
      hprofiler run --backend mpi -- mpirun -np 4 ./mpi_app
      hprofiler run --backend cuda --disasm -- ./app        # adds Disasm tab
      hprofiler run --call-tree --backend cuda -- ./app     # adds Call Tree tab
      hprofiler run --no-ui -o my_trace.json -- ./app       # skip TUI

    \b
    The --call-tree flag captures CPU call stacks at every API interception
    point, enabling a from-main call tree in the TUI. Requires the profiled
    binary to be compiled with -fno-omit-frame-pointer -rdynamic. Adds ~50 us
    overhead per intercepted call; do not use during benchmarking.

    Separate hprofiler options from the program and its arguments with --:

      hprofiler run --backend cuda -- ./my_program --arg1 val
    """
    from src.core.runner import Runner

    backends = _resolve_backends(backend)
    cmd = list(command)

    click.echo(f"[hprofiler] Backends: {', '.join(backends)}", err=True)
    click.echo(f"[hprofiler] Command:  {' '.join(cmd)}", err=True)

    out_path = output
    if not out_path:
        prog_name = Path(cmd[0]).name
        out_path = f"{prog_name}.hprofiler.json"

    env_extra: dict = {}
    if perf_callgraph:
        env_extra["HPROFILER_CALLGRAPH"] = perf_callgraph
    if call_tree:
        env_extra["HPROFILER_CALLSTACK"] = "1"

    runner = Runner(
        command=cmd,
        backends=backends,
        perf_freq=perf_freq,
        env_extra=env_extra,
        collect_disasm=disasm,
    )

    trace = runner.run()
    click.echo(f"\n[hprofiler] Run complete — {len(trace.spans)} events captured", err=True)

    # Save trace
    from src.output import chrome_trace
    chrome_trace.write(trace, out_path)
    click.echo(f"[hprofiler] Trace written to: {out_path}", err=True)

    if summary:
        from src.output.summary import print_summary
        print_summary(trace)

    if ui and trace.all_events:
        from src.ui.app import launch_viewer
        launch_viewer(trace, collect_disasm=disasm)
    elif ui and not trace.all_events:
        click.echo("[hprofiler] No events to display.", err=True)


@cli.command()
@click.argument("trace_file", type=click.Path(exists=True))
@click.option("--disasm/--no-disasm", default=False,
              help="Collect per-kernel disassembly in the background  [default: no]")
def view(trace_file, disasm):
    """Open the TUI viewer for a saved trace JSON file.

    Loads the trace and opens the same terminal UI produced by 'hprofiler run'.
    Tabs shown depend on what data the trace contains:

    \b
      Overview   — command info, backend breakdown, top hotspots
      Timeline   — Gantt view; per-stream lanes for CUDA/ROCm
      Hotspots   — filterable, sortable table (type to filter, 's' to sort)
      Flame      — only when CPU/perf samples are present
      Call Tree  — only when trace was recorded with --call-tree
      Disasm     — only when --disasm is passed to this command

    \b
    Examples:
      hprofiler view app.hprofiler.json
      hprofiler view --disasm app.hprofiler.json
    """
    from src.ui.app import load_trace_from_json, launch_viewer
    click.echo(f"[hprofiler] Loading {trace_file} ...", err=True)
    trace = load_trace_from_json(trace_file, collect_disasm=disasm)
    click.echo(f"[hprofiler] {len(trace.spans)} spans loaded", err=True)
    launch_viewer(trace, collect_disasm=disasm)


def _open_browser(path: str) -> None:
    """Open *path* in a web browser, delegating to the invoking user when under sudo."""
    import os, shutil, subprocess as _sp, sys as _sys
    url = f"file://{os.path.abspath(path)}"

    # When running as root via sudo, re-launch the browser as the original
    # user so it can reach their desktop session.
    sudo_user = os.environ.get("SUDO_USER")
    if sudo_user and os.geteuid() == 0:
        display = os.environ.get("DISPLAY", ":0")
        xauth   = os.environ.get("XAUTHORITY", f"/home/{sudo_user}/.Xauthority")
        browser_env = os.environ.get("BROWSER", "").strip()
        browsers = (
            [browser_env.split()[0]] if browser_env else []
        ) + ["firefox", "firefox-esr", "chromium", "chromium-browser",
             "google-chrome", "google-chrome-stable", "xdg-open"]
        for exe in browsers:
            if shutil.which(exe):
                try:
                    _sp.Popen(
                        ["sudo", "-u", sudo_user,
                         "env",
                         f"DISPLAY={display}",
                         f"XAUTHORITY={xauth}",
                         exe, url],
                        stdout=_sp.DEVNULL, stderr=_sp.DEVNULL,
                    )
                    return
                except FileNotFoundError:
                    continue
        return

    if _sys.platform == "darwin":
        _sp.Popen(["open", url], stderr=_sp.DEVNULL)
        return

    # Prefer explicit browser executables over xdg-open, which may be
    # misconfigured to open non-browser apps (Slack, VS Code, …).
    browser_env = os.environ.get("BROWSER", "").strip()
    for exe in (
        [browser_env.split()[0]] if browser_env else []
    ) + ["firefox", "firefox-esr", "chromium", "chromium-browser",
         "google-chrome", "google-chrome-stable", "brave-browser",
         "epiphany", "epiphany-browser", "falkon", "midori", "xdg-open"]:
        if shutil.which(exe):
            _sp.Popen([exe, url], stdout=_sp.DEVNULL, stderr=_sp.DEVNULL)
            return


@cli.command(
    context_settings={"ignore_unknown_options": True, "allow_extra_args": True}
)
@click.option("--backend", "-b", default=None,
              help="Backend to use when running command  (cuda | rocm | cpu | openmp)")
@click.option("--output", "-o", default=None,
              help="Output file path  (HTML when --html; ignored for TUI)")
@click.option("--html", "use_html", is_flag=True, default=False,
              help="Write an HTML file and open it in the browser instead of the TUI")
@click.argument("target", nargs=-1, type=click.UNPROCESSED)
def roofline(backend, output, use_html, target):
    """Generate an interactive roofline chart using hardware performance counters.

    By default the chart opens as a native TUI (works on HPC clusters without
    a browser).  Pass --html to write an HTML file and open it in the browser.

    Two modes:

    \b
    1. Run the program directly (recommended — uses real hardware counters):
         hprofiler roofline --backend cuda -- ./app args...

    \b
    2. From a saved trace (uses disasm-based estimates — less accurate):
         hprofiler roofline app.hprofiler.json

    Hardware counter tools required:
      CUDA  → ncu  (Nsight Compute, ships with CUDA toolkit)
      ROCm  → rocprof  (ships with ROCm)
      CPU   → perf stat  (linux-tools-$(uname -r))

    If the tool lacks permission to access counters, a fix is shown.
    """
    import os, time
    from src.analysis.device import query_devices
    from src.analysis.roofline import metrics_from_counters

    # ── Mode 1: run command with hardware counters ────────────────────────────
    if backend:
        args = [a for a in target if a != "--"]
        if not args:
            raise click.UsageError(
                "Specify the command to profile after --:\n"
                "  hprofiler roofline --backend cuda -- ./app"
            )

        click.echo(
            f"[hprofiler] Collecting hardware counters via {backend} backend ...",
            err=True,
        )
        click.echo(
            f"[hprofiler] Command: {' '.join(args)}  "
            f"(this re-runs the application)",
            err=True,
        )

        from src.analysis.hwcounters import collect, CounterPermissionError

        try:
            raw_counters = collect(backend, args)
        except FileNotFoundError as e:
            click.echo(f"\n[hprofiler] ✗  Tool not found:\n{e}", err=True)
            raise SystemExit(1)
        except CounterPermissionError as e:
            click.echo(f"\n[hprofiler] ✗  Permission denied:\n{e}", err=True)
            raise SystemExit(1)
        except Exception as e:
            click.echo(f"\n[hprofiler] ✗  Counter collection failed:\n{e}", err=True)
            raise SystemExit(1)

        if not raw_counters:
            click.echo(
                "[hprofiler] No counter data collected. "
                "The program may not have run any kernels.",
                err=True,
            )
            raise SystemExit(1)

        # Query device peaks
        devices = query_devices([backend])
        if not devices:
            click.echo(
                "[hprofiler] Cannot query device capabilities. "
                "Is the GPU/driver available?",
                err=True,
            )
            raise SystemExit(1)
        device = devices[0]

        metrics = [m for c in raw_counters
                   if (m := metrics_from_counters(c, device)) is not None]

        if not metrics:
            click.echo(
                "[hprofiler] No kernels with nonzero FLOPs or DRAM bytes. "
                "The program may be compute-light.",
                err=True,
            )
            raise SystemExit(1)

        name = Path(args[0]).name

        out = output or (Path(args[0]).name + ".roofline.html")
        from src.output.roofline_html import write as _rl_write
        try:
            _rl_write(device, metrics, out, trace_name=name)
        except PermissionError:
            click.echo(
                f"\n[hprofiler] ✗  Cannot write '{out}' — file is owned by another "
                f"user (probably a previous sudo run).\n"
                f"  Fix:  rm {out}\n"
                f"  Or:   hprofiler roofline --backend {backend} -o out.html -- "
                f"{' '.join(args)}",
                err=True,
            )
            raise SystemExit(1)
        click.echo(f"[hprofiler] Roofline chart → {out}", err=True)

        if use_html:
            _open_browser(out)
        else:
            from src.output.roofline_tui import show as _rl_tui
            click.echo("[hprofiler] Opening TUI roofline  (q to quit, w to open HTML) ...",
                       err=True)
            _rl_tui(device, metrics, trace_name=name, html_path=out)
        return

    # ── Mode 2: from saved trace (disasm-based) ───────────────────────────────
    if not target:
        raise click.UsageError(
            "Provide a trace file or use --backend to run with hardware counters:\n"
            "  hprofiler roofline app.hprofiler.json\n"
            "  hprofiler roofline --backend cuda -- ./app"
        )

    trace_file = target[0]
    if not Path(trace_file).exists():
        raise click.BadParameter(f"File not found: {trace_file}")

    click.echo(
        f"[hprofiler] Loading {trace_file} (disasm-based estimates — "
        "less accurate than hardware counters) ...",
        err=True,
    )

    from src.ui.app import load_trace_from_json
    from src.output.roofline_html import write_from_trace

    trace = load_trace_from_json(trace_file, collect_disasm=True)
    for _ in range(40):          # wait up to 12 s for background disasm
        if trace.disasm:
            break
        time.sleep(0.3)

    if not trace.devices:
        click.echo(
            "[hprofiler] No device info in trace. "
            "Re-run with a GPU/CPU backend.",
            err=True,
        )
        raise SystemExit(1)

    out = output or (Path(trace_file).stem + ".roofline.html")
    n = write_from_trace(trace, out)
    if n == 0:
        click.echo(
            "[hprofiler] Nothing to plot.  "
            "Tip: for accurate results use hardware counters:\n"
            f"  hprofiler roofline --backend <backend> -- {trace.metadata.command}",
            err=True,
        )
        raise SystemExit(1)
    click.echo(
        f"[hprofiler] Roofline chart ({n} kernels, disasm estimates) → {out}",
        err=True,
    )

    if use_html:
        _open_browser(out)
    else:
        # TUI mode: collect device/metrics from the trace and show TUI
        from src.analysis.roofline import metrics_from_counters as _mfc
        from src.output.roofline_tui import show as _rl_tui

        device_metrics = []
        for dev in trace.devices:
            dev_metrics = [
                m for kc in trace.kernel_counters.get(dev.name, [])
                if (m := _mfc(kc, dev)) is not None
            ]
            if dev_metrics:
                device_metrics.append((dev, dev_metrics))

        if not device_metrics:
            click.echo(
                "[hprofiler] Nothing to display. "
                "Try --html to see what was estimated.",
                err=True,
            )
            raise SystemExit(1)

        # Show first device (most common case)
        dev, mets = device_metrics[0]
        click.echo("[hprofiler] Opening TUI roofline  (q to quit, w to open HTML) ...",
                   err=True)
        _rl_tui(dev, mets, trace_name=Path(trace_file).stem, html_path=out)


@cli.command(context_settings={"ignore_unknown_options": True, "allow_extra_args": True})
@click.option("--backend", "-b", default=None,
              help="Inject backend hooks (cuda, opencl, rocm, openmp, mpi, …) so their "
                   "API call overhead appears in the CPU flame graph.  "
                   "Comma-separated; same names as 'hprofiler run --backend'.")
@click.option("--output", "-o", default=None,
              help="Output HTML file path  (only used with --html)")
@click.option("--html", "use_html", is_flag=True, default=False,
              help="Write an HTML flamegraph and open in the browser instead of the TUI")
@click.option("--callgraph", default="fp", show_default=True,
              type=click.Choice(["fp", "dwarf", "lbr"]),
              help="perf call-graph method.  fp = frame-pointer (fast, needs "
                   "-fno-omit-frame-pointer).  dwarf = DWARF CFI (slower, "
                   "works with any binary).")
@click.option("--freq", "-F", default=99, show_default=True,
              help="perf sampling frequency (Hz)")
@click.argument("command", nargs=-1, required=True, type=click.UNPROCESSED)
def flamegraph(backend, output, use_html, callgraph, freq, command):
    """Profile COMMAND and show an interactive flame graph in the terminal.

    By default opens a native TUI flamegraph (works on HPC clusters without a
    browser).  Pass --html to write an HTML file and open it in the browser.

    Runs COMMAND under 'perf record --call-graph' to collect CPU stack samples,
    then renders the call tree interactively.

    \b
    TUI controls:
      click / Enter    zoom into frame (fills full width)
      Esc / u          zoom out one level
      r                reset to full view
      /                search / highlight frames by name
      w                write HTML and open in browser
      q                quit

    Use --backend to inject GPU/MPI/OpenMP hooks alongside perf so the flame
    graph shows time spent inside CUDA, OpenCL, ROCm, MPI, etc. API calls
    (kernel launches, synchronisation waits, collectives).

    \b
    Examples:
      hprofiler flamegraph -- ./my_program
      hprofiler flamegraph --backend cuda -- ./cuda_app
      hprofiler flamegraph --html -- ./my_program        (browser mode)
      hprofiler flamegraph --callgraph dwarf -- ./my_program
    """
    import os, shutil as _shutil

    if not _shutil.which("perf"):
        click.echo("[hprofiler] ✗  perf not found — install linux-tools-$(uname -r)",
                   err=True)
        raise SystemExit(1)

    cmd = [a for a in command if a != "--"]
    if not cmd:
        raise click.UsageError("Specify a command after --:\n  hprofiler flamegraph -- ./app")

    env = dict(os.environ)

    # ── Inject backend hooks into the environment ─────────────────────────────
    if backend:
        backends = _resolve_backends(backend)
        if backends:
            from src.backends import ALL_BACKENDS
            from pathlib import Path as _Path
            preload_libs: list[str] = []
            for bname in backends:
                bcls = ALL_BACKENDS.get(bname)
                if bcls is None:
                    continue
                try:
                    b = bcls()
                    for lib in b.preload_libs():
                        if lib and _Path(lib).exists():
                            preload_libs.append(lib)
                    for k, v in b.env_vars().items():
                        if k == "OMP_TOOL_LIBRARIES":
                            existing = env.get(k, "")
                            env[k] = ":".join(filter(None, [existing, v]))
                        else:
                            env.setdefault(k, v)
                except Exception:
                    pass
            if preload_libs:
                existing = env.get("LD_PRELOAD", "")
                env["LD_PRELOAD"] = ":".join(filter(None, [existing] + preload_libs))
            click.echo(
                f"[hprofiler] Backends: {', '.join(backends)}",
                err=True,
            )

    click.echo(
        f"[hprofiler] Recording CPU stacks (--call-graph={callgraph}, -F{freq}) ...",
        err=True,
    )
    click.echo(f"[hprofiler] Command: {' '.join(cmd)}", err=True)

    from src.output.flamegraph import collect_folded_stacks, save as fg_save

    folded = collect_folded_stacks(cmd, env, callgraph=callgraph, freq=freq)

    if not folded.strip():
        click.echo(
            "[hprofiler] ✗  No CPU stacks collected.\n"
            "  Tips:\n"
            "    • Use --callgraph dwarf if the binary lacks frame pointers\n"
            "    • Lower perf_event_paranoid: "
            "sudo sh -c 'echo 0 > /proc/sys/kernel/perf_event_paranoid'\n"
            "    • Make sure the program runs long enough to collect samples",
            err=True,
        )
        raise SystemExit(1)

    total = sum(
        int(ln.rsplit(" ", 1)[1])
        for ln in folded.splitlines()
        if ln.strip() and ln.rsplit(" ", 1)[-1].isdigit()
    )
    click.echo(f"[hprofiler] Collected {total:,} samples.", err=True)

    title = f"{Path(cmd[0]).name} — flame graph ({callgraph})"

    out = output or (Path(cmd[0]).name + ".flamegraph.html")
    try:
        fg_save(folded, out, title)
    except ValueError as e:
        click.echo(f"[hprofiler] ✗  {e}", err=True)
        raise SystemExit(1)
    click.echo(f"[hprofiler] Flame graph → {out}  (open in any browser)", err=True)

    if use_html:
        _open_browser(out)
    else:
        from src.output.flamegraph_tui import show as _fg_tui
        click.echo("[hprofiler] Opening TUI flamegraph  (q to quit, w to open HTML) ...",
                   err=True)
        try:
            _fg_tui(folded, title=title, html_path=out)
        except ValueError as e:
            click.echo(f"[hprofiler] ✗  {e}", err=True)
            raise SystemExit(1)


@cli.command()
@click.argument("trace_file", type=click.Path(exists=True))
@click.option("--top", "-n", default=20, show_default=True,
              help="Number of top hotspots to show")
def summary(trace_file, top):
    """Print a text summary of a saved trace JSON file.

    Groups spans by (name, category), sorts by total time, and shows count,
    total / average duration, and percentage of wall time. Use --top to limit
    how many entries are printed.

    \b
    Example:
      hprofiler summary --top 10 app.hprofiler.json
    """
    from src.ui.app import load_trace_from_json
    from src.output.summary import print_summary
    # Disasm is never used in a text summary — skip the background collection.
    trace = load_trace_from_json(trace_file, collect_disasm=False)
    print_summary(trace, top_n=top)


@cli.command()
def backends():
    """List all backends and their availability on this system.

    Shows whether each backend's required library or tool is present. If a
    backend is unavailable, a hint for installing the missing dependency is
    printed. Use the Name or any listed alias with --backend.

    \b
    Aliases accepted by --backend:
      omp=openmp   hip=rocm   cl=opencl   perf=cpu   hwc=likwid
    """
    from src.backends import ALL_BACKENDS

    # reverse-map: canonical name → aliases
    reverse_aliases: dict[str, list[str]] = {}
    for alias, canon in _ALIASES.items():
        reverse_aliases.setdefault(canon, []).append(alias)

    click.echo("\nAvailable backends:\n")
    for name, cls in ALL_BACKENDS.items():
        backend_obj = cls()
        ok = backend_obj.is_available()
        if ok:
            status = click.style("✓", fg="green") + "  available  "
        else:
            status = click.style("✗", fg="red") + "  unavailable"
        aliases = reverse_aliases.get(name, [])
        alias_str = f"  [alias: {', '.join(aliases)}]" if aliases else ""
        click.echo(f"  {name:<10}  {status}  {backend_obj.description}{alias_str}")

        # Extra hint for OpenMP when libomp is missing
        note = getattr(backend_obj, "availability_note", lambda: "")()
        if note:
            click.echo(f"  {'':10}     {'':13} → {click.style(note, fg='yellow')}")

    click.echo()


@cli.command()
@click.option("--build-dir", default="build", show_default=True,
              help="CMake build directory")
@click.option("--jobs", "-j", default=os.cpu_count() or 4, show_default=True,
              help="Parallel build jobs")
def build(build_dir, jobs):
    """Build the C hook libraries (CUDA, OpenCL, OpenMP, ROCm, NCCL, MPI).

    Runs CMake to compile the hook shared libraries into build/lib/. Only
    hooks whose required headers are detected at configure time are built
    (e.g. libhprofiler_mpi.so requires MPI headers).

    \b
    Libraries produced in build/lib/:
      libhprofiler_cuda.so    CUDA Runtime + Driver API + NVTX
      libhprofiler_opencl.so  OpenCL ICD
      libhprofiler_ompt.so    OpenMP OMPT tool (requires libomp, not libgomp)
      libhprofiler_rocm.so    ROCm/HIP (requires ROCm at /opt/rocm)
      libhprofiler_nccl.so    NCCL collectives (no NCCL headers needed)
      libhprofiler_mpi.so     MPI PMPI wrappers (requires mpicc)

    Re-run after pulling new hook code. Existing .so files are overwritten.
    """
    import subprocess
    build_path = Path(build_dir)
    build_path.mkdir(parents=True, exist_ok=True)

    root = Path(__file__).parent.resolve()

    click.echo(f"[hprofiler] Configuring CMake in {build_path} ...")
    r = subprocess.run(
        ["cmake", str(root.resolve()), "-DCMAKE_BUILD_TYPE=Release"],
        cwd=build_path,
    )
    if r.returncode != 0:
        raise click.ClickException("CMake configure failed")

    click.echo(f"[hprofiler] Building with {jobs} jobs ...")
    r = subprocess.run(["cmake", "--build", ".", f"-j{jobs}"], cwd=build_path)
    if r.returncode != 0:
        raise click.ClickException("Build failed")

    # Copy libs to build/lib in project root
    lib_src = build_path / "lib"
    lib_dst = root / "build" / "lib"
    lib_dst.mkdir(parents=True, exist_ok=True)

    import shutil
    for so in lib_src.glob("*.so*"):
        dst = lib_dst / so.name

        if so.resolve() == dst.resolve():
            click.echo(f"  → {dst} already in place")
            continue

        shutil.copy2(so, dst)
        click.echo(f"  → {dst}")

    click.echo(click.style("[hprofiler] Build complete.", fg="green"))


